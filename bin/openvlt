#!/usr/bin/env bash
set -euo pipefail

OPENVLT_HOME="${OPENVLT_HOME:-$HOME/.openvlt}"
APP_DIR="$OPENVLT_HOME/app"
LOG_DIR="$OPENVLT_HOME/logs"
PORT_FILE="$OPENVLT_HOME/.port"
DEFAULT_PORT=3456
REPO_URL="https://github.com/ericvaish/openvlt.git"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
DIM='\033[2m'
BOLD='\033[1m'
NC='\033[0m'

print_banner() {
  echo ""
  echo -e "${BOLD}  OpenVlt${NC} ${DIM}— Your notes, your files, your server${NC}"
  echo ""
}

get_port() {
  if [ -f "$PORT_FILE" ]; then
    cat "$PORT_FILE"
  else
    echo "$DEFAULT_PORT"
  fi
}

check_deps() {
  local missing=()
  command -v node &>/dev/null || missing+=("node")
  command -v bun &>/dev/null || missing+=("bun")
  command -v pm2 &>/dev/null || missing+=("pm2")

  if [ ${#missing[@]} -gt 0 ]; then
    echo -e "${RED}Missing dependencies: ${missing[*]}${NC}"
    echo "Run the install script first: curl -fsSL https://openvlt.com/install.sh | bash"
    exit 1
  fi
}

cmd_start() {
  check_deps

  local port="${1:-$(get_port)}"
  echo "$port" > "$PORT_FILE"
  mkdir -p "$LOG_DIR"

  if pm2 describe openvlt &>/dev/null 2>&1; then
    echo -e "${YELLOW}OpenVlt is already running.${NC} Use ${CYAN}openvlt restart${NC} to restart."
    return 0
  fi

  echo -e "${DIM}Starting OpenVlt on port $port...${NC}"

  cd "$APP_DIR"
  OPENVLT_PORT="$port" pm2 start ecosystem.config.cjs --env production

  # Wait for the server to be ready
  local retries=0
  while ! curl -sf "http://localhost:$port" &>/dev/null; do
    retries=$((retries + 1))
    if [ "$retries" -gt 15 ]; then
      echo -e "${RED}Server failed to start. Check logs: openvlt logs${NC}"
      exit 1
    fi
    sleep 1
  done

  echo ""
  echo -e "${GREEN}OpenVlt is running${NC} at ${BOLD}http://localhost:$port${NC}"
  echo ""
}

cmd_stop() {
  if ! pm2 describe openvlt &>/dev/null 2>&1; then
    echo -e "${DIM}OpenVlt is not running.${NC}"
    return 0
  fi

  pm2 stop openvlt
  echo -e "${DIM}OpenVlt stopped.${NC}"
}

cmd_restart() {
  check_deps

  local port="$(get_port)"

  if ! pm2 describe openvlt &>/dev/null 2>&1; then
    echo -e "${DIM}OpenVlt is not running. Starting...${NC}"
    cmd_start "$port"
    return 0
  fi

  echo -e "${DIM}Restarting OpenVlt...${NC}"
  cd "$APP_DIR"
  OPENVLT_PORT="$port" pm2 restart ecosystem.config.cjs --env production
  echo -e "${GREEN}OpenVlt restarted${NC} at ${BOLD}http://localhost:$port${NC}"
}

cmd_status() {
  local port="$(get_port)"

  echo ""
  if pm2 describe openvlt &>/dev/null 2>&1; then
    local status
    status=$(pm2 jq openvlt 2>/dev/null | node -e "
      const d = JSON.parse(require('fs').readFileSync('/dev/stdin','utf8'));
      const p = d[0];
      console.log(JSON.stringify({
        status: p.pm2_env.status,
        uptime: p.pm2_env.pm_uptime,
        restarts: p.pm2_env.restart_time,
        memory: p.monit.memory,
        cpu: p.monit.cpu
      }));
    " 2>/dev/null) || true

    if [ -n "$status" ]; then
      local st up mem cpu restarts
      st=$(echo "$status" | node -e "const d=JSON.parse(require('fs').readFileSync('/dev/stdin','utf8')); console.log(d.status)")
      restarts=$(echo "$status" | node -e "const d=JSON.parse(require('fs').readFileSync('/dev/stdin','utf8')); console.log(d.restarts)")
      mem=$(echo "$status" | node -e "const d=JSON.parse(require('fs').readFileSync('/dev/stdin','utf8')); console.log(Math.round(d.memory/1024/1024))")

      if [ "$st" = "online" ]; then
        echo -e "  ${GREEN}● Running${NC} on ${BOLD}http://localhost:$port${NC}"
      else
        echo -e "  ${RED}● $st${NC}"
      fi
      echo -e "  ${DIM}Memory: ${mem}MB | Restarts: $restarts${NC}"
    else
      pm2 describe openvlt 2>/dev/null | head -15
    fi
  else
    echo -e "  ${RED}● Stopped${NC}"
  fi

  # Check for updates
  if [ -d "$APP_DIR/.git" ]; then
    cd "$APP_DIR"
    git fetch --quiet origin 2>/dev/null || true
    local behind
    behind=$(git rev-list --count HEAD..origin/main 2>/dev/null) || behind=0
    if [ "$behind" -gt 0 ]; then
      echo ""
      echo -e "  ${YELLOW}Update available${NC} ($behind commits behind). Run ${CYAN}openvlt update${NC}"
    fi
  fi

  echo ""
}

cmd_update() {
  check_deps

  if [ ! -d "$APP_DIR/.git" ]; then
    echo -e "${RED}Cannot update: not a git installation.${NC}"
    exit 1
  fi

  echo -e "${DIM}Checking for updates...${NC}"
  cd "$APP_DIR"

  git fetch --quiet origin
  local behind
  behind=$(git rev-list --count HEAD..origin/main 2>/dev/null) || behind=0

  if [ "$behind" -eq 0 ]; then
    echo -e "${GREEN}Already up to date.${NC}"
    return 0
  fi

  echo -e "${DIM}Pulling $behind new commits...${NC}"
  git pull --ff-only origin main

  echo -e "${DIM}Installing dependencies...${NC}"
  bun install --frozen-lockfile

  echo -e "${DIM}Building...${NC}"
  bun run build

  # Copy standalone output
  if [ -d ".next/standalone" ]; then
    cp -r .next/standalone/* .
    cp -r .next/static .next/standalone/.next/static 2>/dev/null || true
    cp -r public .next/standalone/public 2>/dev/null || true
  fi

  echo -e "${DIM}Restarting...${NC}"
  cmd_restart

  echo ""
  echo -e "${GREEN}Updated to latest version.${NC}"
}

cmd_logs() {
  if ! pm2 describe openvlt &>/dev/null 2>&1; then
    echo -e "${DIM}OpenVlt is not running. Showing last logs:${NC}"
    echo ""
  fi
  pm2 logs openvlt --lines "${1:-50}" --nostream 2>/dev/null || echo -e "${DIM}No logs found.${NC}"
}

cmd_logs_follow() {
  pm2 logs openvlt
}

cmd_uninstall() {
  echo -e "${YELLOW}This will stop OpenVlt and remove all application files.${NC}"
  echo -e "${BOLD}Your vault data (notes, attachments) will NOT be deleted.${NC}"
  echo ""
  read -rp "Are you sure? (y/N) " confirm
  if [[ "$confirm" != [yY] ]]; then
    echo "Cancelled."
    return 0
  fi

  # Stop and remove from pm2
  pm2 stop openvlt 2>/dev/null || true
  pm2 delete openvlt 2>/dev/null || true
  pm2 save 2>/dev/null || true

  # Remove startup hook
  pm2 unstartup 2>/dev/null || true

  # Remove app files (but NOT user data)
  rm -rf "$APP_DIR"
  rm -rf "$LOG_DIR"
  rm -f "$PORT_FILE"

  # Remove CLI from PATH
  rm -f "$OPENVLT_HOME/bin/openvlt"
  rmdir "$OPENVLT_HOME/bin" 2>/dev/null || true
  rmdir "$OPENVLT_HOME" 2>/dev/null || true

  echo ""
  echo -e "${GREEN}OpenVlt uninstalled.${NC}"
  echo -e "${DIM}Remove the PATH entry from your shell profile if needed.${NC}"
  echo -e "${DIM}Your vault data remains untouched.${NC}"
}

cmd_help() {
  print_banner
  echo "Usage: openvlt <command> [options]"
  echo ""
  echo "Commands:"
  echo -e "  ${CYAN}start${NC} [port]     Start the server (default: port $DEFAULT_PORT)"
  echo -e "  ${CYAN}stop${NC}             Stop the server"
  echo -e "  ${CYAN}restart${NC}          Restart the server"
  echo -e "  ${CYAN}status${NC}           Show server status and check for updates"
  echo -e "  ${CYAN}update${NC}           Pull latest version, rebuild, and restart"
  echo -e "  ${CYAN}logs${NC} [lines]     Show recent logs (default: 50 lines)"
  echo -e "  ${CYAN}logs -f${NC}          Follow logs in real-time"
  echo -e "  ${CYAN}uninstall${NC}        Stop and remove OpenVlt (keeps your notes)"
  echo ""
  echo "Examples:"
  echo -e "  ${DIM}openvlt start${NC}          # Start on port $DEFAULT_PORT"
  echo -e "  ${DIM}openvlt start 8080${NC}     # Start on port 8080"
  echo -e "  ${DIM}openvlt logs -f${NC}        # Follow live logs"
  echo ""
}

# Main
case "${1:-}" in
  start)    shift; cmd_start "${1:-}" ;;
  stop)     cmd_stop ;;
  restart)  cmd_restart ;;
  status)   cmd_status ;;
  update)   cmd_update ;;
  logs)
    if [ "${2:-}" = "-f" ]; then
      cmd_logs_follow
    else
      cmd_logs "${2:-50}"
    fi
    ;;
  uninstall) cmd_uninstall ;;
  help|--help|-h) cmd_help ;;
  "")       cmd_help ;;
  *)
    echo -e "${RED}Unknown command: $1${NC}"
    echo ""
    cmd_help
    exit 1
    ;;
esac
